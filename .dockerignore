# Node dependencies — reinstalled inside the build stage
node_modules/

# Angular build output — built inside the container
dist/

# Git history and CI metadata
.git/
.gitignore
.gitattributes
.github/
.bitbucket/

# Editor and OS artefacts
.vscode/
.idea/
*.sw[po]
.DS_Store
Thumbs.db

# Test and dev tooling output
coverage/
.angular/cache/

# Docs and diagrams — not needed in the image
docs/
*.md

# Deployment Helm chart — not part of the application image.
# Exclude the chart files but KEEP deploy/nginx/ — the runtime stage copies
# deploy/nginx/nginx.conf into the image (excluding all of deploy/ broke the build).
deploy/*
!deploy/nginx

# Environment files — secrets must never enter the image
.env
.env.*
